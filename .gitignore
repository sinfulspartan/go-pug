vendor/
Godeps/
pkg/mod/

# Go modules (usually you commit go.sum; uncomment if you prefer to ignore)
/go.sum

# IDEs and editors
.vscode/
.idea/
*.iml
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

